name: Auto Sync Play Store Apps

on:
  schedule:
    # Runs automatically at 00:00 UTC (Midnight) every single day
    - cron: '0 0 * * *'
  workflow_dispatch: # Allows you to press a manual update button whenever you want

jobs:
  build-and-sync:
    runs-on: ubuntu-latest
    permissions:
      contents: write # Grants GitHub permission to modify index.html

    steps:
    - name: Checkout Code
      uses: actions/checkout@v4

    - name: Set Up Python Environment
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'

    - name: Run PlayStore Scraper Script
      run: python updater.py

    - name: Commit and Push Updates
      run: |
        git config --global user.name "github-actions[bot]"
        git config --global user.email "github-actions[bot]@users.noreply.github.com"
        git add index.html
        git diff --quiet && git diff --staged --quiet || (git commit -m "Auto-updated Play Store applications list" && git push)
